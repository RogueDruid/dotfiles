[
    {
        "name": "topbar",
        "layer": "top",
        "position": "top",
        "height": 30,
        "modules-left": [
            "hyprland/workspaces"
        ],
        "modules-center": [
            "clock"
        ],
        "modules-right": [
            "pulseaudio",
            "idle_inhibitor"
        ],
        "idle_inhibitor": {
            "format": "{icon}",
            "format-icons": {
                "activated": "´ü«",
                "deactivated": "´ü░"
            }
        },
        "clock": {
            "interval": 1,
            "format": "<b>{:%H:%M:%S}</b>",
            "format-alt": "{:%Y-%m-%d}",
            "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
        },
        "cpu": {
            "format": "´őŤ {usage}%",
            "tooltip": false
        },
        "disk": {
            "format": "´éá {}%",
            "tooltip-format": "{used} / {total} used"
        },
        "memory": {
            "format": "´âë {}%",
            "tooltip-format": "{used:0.1f}G / {total:0.1f}G used"
        },
        "temperature": {
            "critical-threshold": 80,
            "format": "{icon} {temperatureC}┬░C",
            "format-icons": ["´őő", "´őŐ", "´őë", "´őł", "´őç"]
        },
        "pulseaudio": {
            "scroll-step": 1,
            "format": "{icon} {volume}%{format_source}",
            "format-bluetooth": "{icon}´Őö {volume}%{format_source}",
            "format-bluetooth-muted": "´ÇŽ {icon}´Őö{format_source}",
            "format-muted": "´Üę {format_source}",
            "format-source": " ´ä░ {volume}%",
            "format-source-muted": " ´ä▒",
            "format-icons": {
                "headphone": "´Çą",
                "phone": "´éĽ",
                "portable": "´éĽ",
                "car": "´ć╣",
                "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
            },
            "on-click": "pavucontrol"
        }
    },
    {
        "name": "bottombar",
        "layer": "top",
        "position": "bottom",
        "height": 36,
        "modules-left": ["tray"],
        "modules-center": ["wlr/taskbar"],
        "modules-right": ["tray"],
        "tray": {
            "icon-size": 13,
            "spacing": 10
        },
        "wlr/taskbar": {
            "format": "{icon} {name}",
            "icon-size": 13,
            "tooltip": false,
            "on-click": "activate",
            "on-click-right": "close",
            "app_ids-mapping": {
                "gnome-terminal-server": "org.gnome.Terminal"
            }
        },
        "sway/mode": {
            "format": "<span style=\"italic\">{}</span>"
        }
    }
]